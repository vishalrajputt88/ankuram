{% comment %}
  ============================================================
  article.liquid — RightShift Blog (Horizon Theme)

  Metafields:
    custom.toc_enabled         → Boolean
    custom.intro_text          → Rich text  → render: | metafield_tag
    custom.highlight_box       → Metaobject (highlight_box)
                                   fields: box_title, box_image, bullet_items (list)
    custom.conclusion_title    → Single line text
    custom.conclusion_text     → Rich text  → render: | metafield_tag
    custom.related_articles    → List metaobject (related_article)
                                   fields: title, category_tag, read_time, image, article_link
    custom.blog_faq            → List metaobject (blog_faq)
                                   fields: question (single line), answer (rich text)
  ============================================================
{% endcomment %}




{%- assign toc_on      = article.metafields.custom.toc_enabled.value -%}
{%- assign hbox        = article.metafields.custom.highlight_box.value -%}
{%- assign conc_title  = article.metafields.custom.conclusion_title.value -%}
{%- assign rel_list    = article.metafields.custom.related_articles.value -%}
{%- assign faq_list    = article.metafields.custom.blog_faq.value -%}

{% render 'schema-article' %}
<style>
/* ── Scoped entirely to #rs-blog — zero theme conflict ── */
#rs-blog { all: initial; display: block; }
#rs-blog *, #rs-blog *::before, #rs-blog *::after {
  box-sizing: border-box;
}

ul, li { font-family: 'Poppins' !important; }


.rs-body .standard-markdown { display: flex !important;  }

#rs-blog {
  --c-cream  : #FDF5DA;
  --c-dark   : #1C1A14;
  --c-olive  : #5C6B3A;
  --c-rust   : #C4612A;
  --c-sand   : #E8DFC8;
  --c-sandd  : #D4C9A8;
  --c-white  : #FDFBF7;
  --c-text   : #2C2A22;
  --c-muted  : #6B6456;
  --c-border : #DDD5BE;
  background : var(--c-cream);
  color      : var(--c-text);
  line-height: 1.7;
  font-size  : 15px;
}

/* HERO */
#rs-blog .rs-hero {
  width: 100%; height: 329px;
  overflow: hidden; background: #c8b89a;
}
#rs-blog .rs-hero img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 35%;
  display: block;
}

/* WRAPPER */
#rs-blog .rs-wrap {
  max-width: 1160px;
  margin: 0 auto;
  padding: 44px 28px 80px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 290px;
  gap: 60px;
  align-items: start;
}

/* META */
#rs-blog .rs-meta {
  display: flex; align-items: center;
  gap: 10px; flex-wrap: wrap;
  font-size: 13px; color: var(--c-muted);
  margin-bottom: 10px;
}
#rs-blog .rs-meta strong {
  font-weight: 600; color: var(--c-text);     font-family: 'Poppins';
}
#rs-blog .rs-meta .rs-dot {
  width: 3px; height: 3px; border-radius: 50%;
  background: var(--c-muted); display: inline-block; flex-shrink: 0;
}

/* TITLE */
#rs-blog .rs-h1 {
  
  font-size: clamp(26px, 3.5vw, 42px);
  font-weight: 800; color: var(--c-dark);
  line-height: 1.18; margin: 0 0 26px;
  letter-spacing: -0.5px;
}

/* TOC */
#rs-blog .rs-toc {
  background: #ffffff82;
    border: 1px solid #000;
    border-radius: 12px;
    padding: 22px 28px;
    margin-bottom: 34px;
    max-width: 794px;
}
#rs-blog .rs-toc-lbl {
 font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--c-muted);
    margin: 0 0 7px;
    display: block;
}
#rs-blog .rs-toc ol {
  list-style: none; padding: 0; margin: 0;
  counter-reset: toc-cnt;
}
#rs-blog .rs-toc ol li {
  counter-increment: toc-cnt;
  display: flex; align-items: baseline;
  gap: 10px; margin-bottom: 0px;
  font-family: 'Poppins';
}
#rs-blog .rs-toc ol li:last-child { margin-bottom: 0; }
#rs-blog .rs-toc ol li::before {
  content: counter(toc-cnt) ".";
  font-size: 12px; font-weight: 700;
  color: var(--c-olive); min-width: 18px; flex-shrink: 0;
}
#rs-blog .rs-toc ol li a {
  color: var(--c-text); text-decoration: none;
  font-size: 18px; line-height: 1.5;
  border-bottom: 1px solid transparent;
  transition: color .2s, border-color .2s;
}
#rs-blog .rs-toc ol li a:hover,
#rs-blog .rs-toc ol li a.rs-active {
  color: var(--c-rust);
  border-bottom-color: var(--c-rust);
}
p, span {     font-family: 'Poppins' !important; }
h1, h2, h3, h4, h5, h6 {     font-family: 'Poppins' !important; }

h2 code {  font-family: 'Poppins' !important; }

/* INTRO */
#rs-blog .rs-intro {
  
  font-size: 15.5px; line-height: 1.85;
  color: var(--c-text); margin-bottom: 36px;
}
#rs-blog .rs-intro p { margin: 0 0 14px; font-size: 17px; color: #000; }
#rs-blog .rs-intro p:last-child { margin-bottom: 0; }
#rs-blog .rs-intro strong { color: var(--c-dark); font-weight: 600; }

/* BODY (article.content) */
#rs-blog .rs-body { font-size: 15px; line-height: 1.82; color: var(--c-text); }
#rs-blog .rs-body p { margin: 0 0 16px; font-size: 17px; color: #000; }
#rs-blog .rs-body h2 {
  
  font-size: 30px; font-weight: 700; color: var(--c-dark);
  margin: 20px 0 14px; padding-bottom: 11px;
  scroll-margin-top: 22px; line-height: 1.25;
}
#rs-blog .rs-body h3 {
  
  font-size: 19px; font-weight: 600; color: var(--c-dark);
  margin: 30px 0 10px;
}
#rs-blog .rs-body ul,
#rs-blog .rs-body ol { padding-left: 22px; margin: 0 0 18px; }
#rs-blog .rs-body li  { margin-bottom: 8px; }
#rs-blog .rs-body strong { font-weight: 600; color: var(--c-dark); }
#rs-blog .rs-body a  { color: var(--c-rust); text-decoration: underline; }
#rs-blog .rs-body img { max-width: 100%; border-radius: 10px; margin: 20px 0; display: block; }
#rs-blog .rs-body blockquote {
  border-left: 4px solid var(--c-olive); margin: 24px 0;
  padding: 14px 20px; background: var(--c-white);
  border-radius: 0 8px 8px 0; font-style: italic; color: var(--c-muted);
}

/* HIGHLIGHT BOX */
#rs-blog .rs-hbox {
  display: grid; grid-template-columns: 250px 1fr;
  border: 1.5px solid var(--c-border); border-radius: 14px;
  overflow: hidden; margin: 44px 0; background: var(--c-white);
  box-shadow: 0 4px 22px rgba(28,26,20,.07);
}
#rs-blog .rs-hbox-img { min-height: 240px; overflow: hidden; background: var(--c-sand); }
#rs-blog .rs-hbox-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
#rs-blog .rs-hbox-body { padding: 28px 26px; display: flex; flex-direction: column; justify-content: center; }
#rs-blog .rs-hbox-body h3 {
  
  font-size: 20px; font-weight: 700; color: var(--c-dark);
  margin: 0 0 16px; line-height: 1.3;
}
#rs-blog .rs-hbox-body ul { list-style: none; padding: 0; margin: 0; }
#rs-blog .rs-hbox-body ul li {
  display: flex; gap: 10px;
  font-size: 13.5px; line-height: 1.65;
  margin-bottom: 13px; color: var(--c-text); font-family: 'Poppins';
}
#rs-blog .rs-hbox-body ul li:last-child { margin-bottom: 0; }
#rs-blog .rs-hbox-body ul li::before { content: '–'; color: var(--c-olive); font-weight: 700; flex-shrink: 0; }
#rs-blog .rs-hbox-body ul li strong { font-weight: 600; color: var(--c-dark); }

/* DARK BOX */
#rs-blog .rs-dark {
  background: var(--c-dark); border-radius: 14px;
  padding: 34px 38px; margin: 44px 0;
}
#rs-blog .rs-dark h2 {
  font-size: 22px; font-weight: 700; color: var(--c-cream);
  margin: 0 0 16px; line-height: 1.3;
  border: none !important; padding: 0 !important;
}
#rs-blog .rs-dark p { font-size: 14.5px; line-height: 1.85; color: rgba(245,240,232,.86); margin: 0 0 14px; }
#rs-blog .rs-dark p:last-child { margin: 0; }

/* FAQ */
#rs-blog .rs-faq { margin-top: 52px; padding-top: 40px; border-top: 2px solid var(--c-sandd); }
#rs-blog .rs-faq-title {
  font-size: 28px; font-weight: 700; color: var(--c-dark);
  margin: 0 0 26px; position: relative; padding-bottom: 13px;
}
#rs-blog .rs-faq-title::after {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 44px; height: 3px; background: var(--c-olive); border-radius: 2px;
}
#rs-blog .rs-faq-item { border-bottom: 1px solid var(--c-border); }
#rs-blog .rs-faq-btn {     font-family: 'Poppins' !important;
  all: unset; width: 100%; cursor: pointer;
  padding: 18px 0; display: flex; justify-content: space-between;
  align-items: center; gap: 16px;
 font-size: 15px;
  font-weight: 600; color: var(--c-dark);
  transition: color .2s;
}
#rs-blog .rs-faq-btn:hover { color: var(--c-rust); }
#rs-blog .rs-faq-ico {
  flex-shrink: 0; width: 30px; height: 30px;
  border: 1.5px solid var(--c-border); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 300; line-height: 1;
  color: var(--c-olive);
  transition: transform .3s, background .3s, border-color .3s, color .3s;
  pointer-events: none;
}
#rs-blog .rs-faq-item.rs-open .rs-faq-ico {
  transform: rotate(45deg);
  background: var(--c-olive); border-color: var(--c-olive); color: #fff;
}
#rs-blog .rs-faq-panel {
  max-height: 0; overflow: hidden;
  transition: max-height .38s ease;
}
#rs-blog .rs-faq-panel-inner {
  padding: 0 0 20px;
  font-size: 14.5px; line-height: 1.8; color: var(--c-muted);
}
#rs-blog .rs-faq-panel-inner p { margin: 0 0 10px; }

/* SIDEBAR */
#rs-blog .rs-sidebar { position: sticky; top: 28px; }
#rs-blog .rs-sidebar-title {
  
  font-size: 22px; font-weight: 700; color: var(--c-dark);
  margin: 0 0 22px;
}
#rs-blog .rs-card {
  display: block; background: var(--c-white);
  border-radius: 12px; overflow: hidden;
  margin-bottom: 20px; border: 1px solid var(--c-border);
  text-decoration: none; color: inherit;
  box-shadow: 0 2px 12px rgba(28,26,20,.05);
  transition: transform .22s, box-shadow .22s;
}
#rs-blog .rs-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 28px rgba(28,26,20,.12);
}
#rs-blog .rs-card-thumb {
  position: relative; height: 160px;
  overflow: hidden; background: var(--c-sand);
}
#rs-blog .rs-card-thumb img {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: transform .4s;
}
#rs-blog .rs-card:hover .rs-card-thumb img { transform: scale(1.06); }
#rs-blog .rs-card-badge {
  position: absolute; top: 10px; right: 10px;
  background: rgba(28,26,20,.7); color: #fff;
  font-size: 11px; font-weight: 500;
  padding: 4px 10px; border-radius: 20px;
}
#rs-blog .rs-card-body { padding: 14px 16px 18px; }
#rs-blog .rs-card-meta {
  display: flex; align-items: center;
  gap: 8px; margin-bottom: 8px; flex-wrap: wrap;
}
#rs-blog .rs-card-tag {
  font-size: 10px; font-weight: 700;
  letter-spacing: .8px; text-transform: uppercase;
  background: #E8F0DC; color: #2D5016;
  padding: 3px 9px; border-radius: 3px;
}
#rs-blog .rs-card-date { font-size: 11px; color: var(--c-muted); }
#rs-blog .rs-card-title {
  
  font-size: 14.5px; font-weight: 600;
  color: var(--c-dark); line-height: 1.42; margin: 0;
}

/* RESPONSIVE */
@media (max-width: 920px) {
  #rs-blog .rs-wrap {
    grid-template-columns: 1fr;
    gap: 40px; padding: 28px 18px 60px;
  }
  #rs-blog .rs-sidebar {
    position: static;
    border-top: 1.5px solid var(--c-border);
    padding-top: 36px;
  }
  #rs-blog .rs-hbox { grid-template-columns: 1fr; }
  #rs-blog .rs-hbox-img { min-height: 200px; height: 200px; }
  #rs-blog .rs-hero { height: 180px; }
}
@media (max-width: 540px) {
  #rs-blog .rs-hero { height: 140px; }
}
</style>

<div id="rs-blog">

  <!-- HERO -->
  {% if article.image %}
  <div class="rs-hero">
    <img
      src="{{ article.image | image_url: width: 1400 }}"
      alt="{{ article.image.alt | default: article.title | escape }}"
      loading="eager"
    >
  </div>
  {% endif %}

  <!-- GRID -->
  <div class="rs-wrap">

    <!-- ═══ MAIN ═══ -->
    <main>

      <!-- Meta -->
      <div class="rs-meta">
        <strong>{{ article.author }}</strong>
        <span class="rs-dot"></span>
        <span>{{ article.published_at | date: '%d %b %Y' }}</span>
      </div>

      <!-- Title -->
      <h1 class="rs-h1">{{ article.title }}</h1>

      <!-- TOC -->
      {% if toc_on %}
      <div class="rs-toc">
        <span class="rs-toc-lbl">In This Article</span>
        <ol id="rs-toc-list"></ol>
      </div>
      {% endif %}

      <!-- Intro Text — Rich text: metafield_tag filter -->
      {% if article.metafields.custom.intro_text != blank %}
      <div class="rs-intro">
        {{ article.metafields.custom.intro_text | metafield_tag }}
      </div>
      {% endif %}

      <!-- Article Body -->
      <div class="rs-body" id="rs-body">
        {{ article.content }}
      </div>

      <!-- Highlight Box — Dynamic from metaobject -->
      {% if hbox != blank %}
      <div class="rs-hbox">
        <div class="rs-hbox-img">
          {% if hbox.box_image.value != blank %}
          <img
            src="{{ hbox.box_image.value | image_url: width: 500 }}"
            alt="{{ hbox.box_title.value | escape }}"
            loading="lazy"
          >
          {% endif %}
        </div>
        <div class="rs-hbox-body">
          {% if hbox.box_title.value != blank %}
          <h3>{{ hbox.box_title.value }}</h3>
          {% endif %}
          {% if hbox.bullet_items.value != blank %}
          <ul>
            {% for item in hbox.bullet_items.value %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </div>
      {% endif %}
      <!-- Dark Conclusion Box — Dynamic -->
      {% if conc_title != blank or article.metafields.custom.conclusion_text != blank %}
      <div class="rs-dark">
       {% if conc_title != blank %}
<p class="rs-dark-title">{{ conc_title }}</p>
{% endif %}
        {% if article.metafields.custom.conclusion_text != blank %}
          {{ article.metafields.custom.conclusion_text | metafield_tag }}
        {% endif %}
      </div>
      {% endif %}

      <!-- FAQ -->
      {% if faq_list != blank and faq_list.size > 0 %}
      <div class="rs-faq">
        <h2 class="rs-faq-title">Frequently Asked Questions</h2>
        {% for faq in faq_list %}
        <div
          class="rs-faq-item"
          itemscope itemprop="mainEntity"
          itemtype="https://schema.org/Question"
        >
          <button
            class="rs-faq-btn"
            aria-expanded="false"
            aria-controls="rs-faq-{{ forloop.index }}"
            itemprop="name"
          >
            {{ faq.question.value }}
            <span class="rs-faq-ico">+</span>
          </button>
          <div
            class="rs-faq-panel"
            id="rs-faq-{{ forloop.index }}"
            itemscope itemprop="acceptedAnswer"
            itemtype="https://schema.org/Answer"
          >
            <div class="rs-faq-panel-inner" itemprop="text">
              {{ faq.answer | metafield_tag }}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </main>

    <!-- ═══ SIDEBAR ═══ -->
    <!-- ═══ SIDEBAR ═══ -->
<aside class="rs-sidebar">
  <h3 class="rs-sidebar-title">Related articles</h3>

  {%- assign shown = 0 -%}

  {%- comment -%} Same category/tag wale pehle {%- endcomment -%}
  {%- for a in blog.articles -%}
    {%- if shown >= 3 -%}{%- break -%}{%- endif -%}
    {%- if a.id == article.id -%}{%- continue -%}{%- endif -%}
    {%- assign is_related = false -%}
    {%- for tag in a.tags -%}
      {%- if article.tags contains tag -%}
        {%- assign is_related = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if is_related -%}
      <a href="{{ a.url }}" class="rs-card">
        <div class="rs-card-thumb">
          {%- if a.image -%}
          <img src="{{ a.image | image_url: width: 400 }}" alt="{{ a.title | escape }}" loading="lazy">
          {%- endif -%}
          <span class="rs-card-badge">
            {%- assign mins = a.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
            {{ mins }} min read
          </span>
        </div>
        <div class="rs-card-body">
          <div class="rs-card-meta">
            {%- if a.tags.first -%}
            <span class="rs-card-tag">{{ a.tags.first | upcase }}</span>
            {%- endif -%}
            <span class="rs-card-date">{{ a.published_at | date: '%d %b %Y' }}</span>
          </div>
          <h4 class="rs-card-title">{{ a.title }}</h4>
        </div>
      </a>
      {%- assign shown = shown | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Agar 3 se kam aaye toh latest se fill {%- endcomment -%}
  {%- if shown < 3 -%}
    {%- for a in blog.articles -%}
      {%- if shown >= 3 -%}{%- break -%}{%- endif -%}
      {%- if a.id == article.id -%}{%- continue -%}{%- endif -%}
      {%- assign is_related = false -%}
      {%- for tag in a.tags -%}
        {%- if article.tags contains tag -%}
          {%- assign is_related = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- unless is_related -%}
        <a href="{{ a.url }}" class="rs-card">
          <div class="rs-card-thumb">
            {%- if a.image -%}
            <img src="{{ a.image | image_url: width: 400 }}" alt="{{ a.title | escape }}" loading="lazy">
            {%- endif -%}
            <span class="rs-card-badge">
              {%- assign mins = a.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
              {{ mins }} min read
            </span>
          </div>
          <div class="rs-card-body">
            <div class="rs-card-meta">
              {%- if a.tags.first -%}
              <span class="rs-card-tag">{{ a.tags.first | upcase }}</span>
              {%- endif -%}
              <span class="rs-card-date">{{ a.published_at | date: '%d %b %Y' }}</span>
            </div>
            <h4 class="rs-card-title">{{ a.title }}</h4>
          </div>
        </a>
        {%- assign shown = shown | plus: 1 -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}

</aside>

  </div>
</div>

<script>
(function () {

  /* ── TOC ── */
  var tocList = document.getElementById('rs-toc-list');
  if (tocList) {
    var body = document.getElementById('rs-body');
    var h2s = body ? Array.from(body.querySelectorAll('h2')).filter(function(h) {
  return h.textContent.trim() !== '';
}) : [];
    if (!h2s.length) {
      var tocBox = tocList.closest('.rs-toc');
      if (tocBox) tocBox.style.display = 'none';
    } else {
      var tocLinks = [];
      h2s.forEach(function (h, i) {
        var id = 'rs-sec-' + i;
        h.id = id;
        h.style.scrollMarginTop = '22px';

        var li  = document.createElement('li');
        var a   = document.createElement('a');
        a.href        = '#' + id;
        a.textContent = h.textContent.replace(/^\d+[\.\s]+/, '').trim();

        a.addEventListener('click', function (e) {
          e.preventDefault();
          var target = document.getElementById(id);
          if (!target) return;
          var top = target.getBoundingClientRect().top + window.pageYOffset - 18;
          window.scrollTo({ top: top, behavior: 'smooth' });
        });

        tocLinks.push(a);
        li.appendChild(a);
        tocList.appendChild(li);
      });

      /* Scroll active highlight */
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (!en.isIntersecting) return;
          tocLinks.forEach(function (l) { l.classList.remove('rs-active'); });
          var idx = Array.from(h2s).indexOf(en.target);
          if (idx >= 0 && tocLinks[idx]) tocLinks[idx].classList.add('rs-active');
        });
      }, { rootMargin: '-5% 0px -78% 0px' });

      h2s.forEach(function (h) { io.observe(h); });
    }
  }

  /* ── FAQ ACCORDION ── */
  document.querySelectorAll('.rs-faq-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item  = btn.closest('.rs-faq-item');
      var panel = document.getElementById(btn.getAttribute('aria-controls'));
      var isOpen = item.classList.contains('rs-open');

      /* Close all */
      document.querySelectorAll('.rs-faq-item').forEach(function (i) {
        i.classList.remove('rs-open');
        i.querySelector('.rs-faq-btn').setAttribute('aria-expanded', 'false');
        var p = i.querySelector('.rs-faq-panel');
        if (p) p.style.maxHeight = '0';
      });

      /* Open clicked */
      if (!isOpen) {
        item.classList.add('rs-open');
        btn.setAttribute('aria-expanded', 'true');
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
    });
  });

})();
</script>
