<section class="video-carousel-section">

  <!-- 🔝 TOP HEADER -->
  <div class="vc-header">
    <div class="vc-left">
      
      {% if section.settings.profile_image != blank %}
        <img src="{{ section.settings.profile_image | image_url }}" class="vc-avatar">
      {% endif %}

      <div class="vc-text">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtext }}</p>
      </div>

    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="vc-button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>

  <!-- 🎥 VIDEO CAROUSEL -->
  <div class="video-carousel">
    <div class="video-track">
      {% for block in section.blocks %}
        <div class="video-item"
          data-username="{{ block.settings.username }}"
          data-caption="{{ block.settings.caption }}"
          data-product-title="{{ block.settings.product_title }}"
          data-product-price="{{ block.settings.product_price }}"
          data-product-link="{{ block.settings.product_link }}"
          {% if block.settings.product_image != blank %}
            data-product-image="{{ block.settings.product_image | image_url: width: 200 }}"
          {% endif %}
        >

          {% if block.settings.video_file != blank %}
            {{
              block.settings.video_file 
              | video_tag: autoplay: true, loop: true, muted: true, playsinline: true
            }}
          {% elsif block.settings.video_url != blank %}
            <video src="{{ block.settings.video_url }}" autoplay muted loop playsinline></video>
          {% endif %}

          <!-- ▶ PLAY BUTTON -->
          <div class="vc-play-btn">▶</div>

        </div>
      {% endfor %}
    </div>
  </div>

</section>

<!-- 🔥 MODAL -->
<div class="vc-modal" id="vcModal">
  <div class="vc-modal-wrap">

    <!-- ❌ CLOSE -->
    <span class="vc-close">&times;</span>

    <!-- ⬅ LEFT VIDEO -->
    <div class="vc-modal-left">
      <video id="vcModalVideo" autoplay muted loop playsinline></video>
    </div>

    <!-- ➡ RIGHT CONTENT -->
    <div class="vc-modal-right">
      
      <div class="vc-user">
        {% if section.settings.profile_image != blank %}
          <img src="{{ section.settings.profile_image | image_url }}">
        {% endif %}
        <h3 id="vcModalUsername">@username</h3>
        <p id="vcModalCaption">Daily wellness designed to support health that endures.</p>
      </div>

      <h4>Related product</h4>

      <div class="vc-product">
        <img id="vcModalProductImage" src="" alt="">
        <div>
          <p><strong id="vcModalProductTitle">Product Name</strong></p>
          <p id="vcModalProductPrice">$0.00</p>
          <a id="vcModalProductLink" href="#">View product</a>
        </div>
      </div>

    </div>

  </div>
</div>

<style>
.video-carousel-section {
    padding: 40px;
    background: #f7f8f7;
    margin: 50px auto 0px;
    max-width: 1300px;
}

/* HEADER */
.vc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
}

.vc-left {
  display: flex;
  align-items: center;
  gap: 15px;
}

.vc-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  object-fit: cover;
}

.vc-text h2 {
  margin: 0;
  font-size: 22px;
  letter-spacing: 2px;
}

.vc-text p {
  margin: 0;
  color: #666;
}

/* BUTTON */
.vc-button {
  padding: 12px 24px;
  background: #fff;
  text-decoration: none;
  color: #000;
  border: 1px solid #ddd;
  font-size: 14px;
}

/* VIDEO */
.video-carousel {
  overflow: hidden;
}

.video-track {
  display: flex;
  gap: 20px;
  animation: scroll 20s linear infinite;
}

.video-item {
  min-width: 25%;
  position: relative;
}

.video-item video {
  width: 100%;
  height: 500px;
  object-fit: cover;
  border-radius:5px;
}

/* ▶ PLAY BUTTON */
.vc-play-btn {
  position: absolute;
  bottom: 15px;
  left: 15px;
  color: #fff;
  font-size: 18px;
  padding: 10px 14px;
  border-radius: 50%;
  cursor: pointer;
}

/* MODAL */
.vc-modal {
  display: none;
  position: fixed;
  z-index: 9999;
  inset: 0;
  background: rgba(0,0,0,0.7);
}

.vc-modal-wrap {
  display: flex;
  width: 90%;
  height: 90%;
  margin: auto;
  background: #fff;
}

.vc-modal-left {
  width: 60%;
  background: #000;
}

.vc-modal-left video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.vc-modal-right {
  width: 40%;
  padding: 40px;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.vc-user {
  text-align: center;
}

.vc-user img {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  margin-bottom: 10px;
}

.vc-user h3 {
  margin:20px 0;
}

.vc-user p {
  color: #666;
  font-size: 14px;
   margin:20px 0;
}

.vc-product {
  display: flex;
  gap: 15px;
  margin-top: 20px;
  border: 1px solid #eee;
  padding: 15px;
}

.vc-product img {
  width: 60px;
}

.vc-product a {
  font-size: 14px;
  text-decoration: underline;
}

.vc-close {
  position: absolute;
  right: 30px;
  top: 20px;
  font-size: 28px;
  cursor: pointer;
}

@keyframes scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@media (max-width: 768px) {
.video-carousel-section{
    padding:40px 10px;
}
  .video-track {
    gap: 15px;
    animation: scroll 12s linear infinite;
  }

  .video-item {
    min-width: 60%;
  }

  .video-item video {
    height: 400px;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }
}
</style>

<!-- 🔥 JS -->
<script>
document.querySelectorAll('.vc-play-btn').forEach((btn) => {
  btn.addEventListener('click', function() {
    const item = this.parentElement;
    const video = item.querySelector('video');
    const modal = document.getElementById('vcModal');
    const modalVideo = document.getElementById('vcModalVideo');

    // Populate modal with block data
    const username = item.dataset.username || '@username';
    const caption = item.dataset.caption || '';
    const productTitle = item.dataset.productTitle || 'Product Name';
    const productPrice = item.dataset.productPrice || '';
    const productLink = item.dataset.productLink || '#';
    const productImage = item.dataset.productImage || '';

    document.getElementById('vcModalUsername').textContent = username;
    document.getElementById('vcModalCaption').textContent = caption;
    document.getElementById('vcModalProductTitle').textContent = productTitle;
    document.getElementById('vcModalProductPrice').textContent = productPrice;
    document.getElementById('vcModalProductLink').href = productLink;
    
    const imgEl = document.getElementById('vcModalProductImage');
    if (productImage) {
      imgEl.src = productImage;
      imgEl.style.display = 'block';
    } else {
      imgEl.style.display = 'none';
    }

    // Play video in modal
    modal.style.display = "flex";
    modalVideo.src = video.currentSrc || video.src;
    modalVideo.muted = true;
    modalVideo.volume = 0;
    modalVideo.play();
  });
});

document.querySelector('.vc-close').addEventListener('click', function() {
  const modal = document.getElementById('vcModal');
  const modalVideo = document.getElementById('vcModalVideo');
  modal.style.display = "none";
  modalVideo.pause();
});
</script>

{% schema %}
{
  "name": "Video Carousel",
  "settings": [
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "Profile Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ETERNAL"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Follow us"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "VIEW MORE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video_file",
          "label": "Upload Video"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Or Video URL"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Instagram Username",
          "default": "@username"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption / Description",
          "default": "Daily wellness designed to support health that endures."
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Title",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Product Price",
          "default": "$61.00"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Carousel"
    }
  ]
}
{% endschema %}