{% comment %}
  Section: Right Shift Blog Grid
  Renders blog articles using Liquid (server-side) so it works
  in both the Shopify theme editor preview AND on the live site.
  Tab filtering is handled client-side via JavaScript after render.
{% endcomment %}

{% assign blog_handle = section.settings.blog_handle | default: 'news' %}
{% assign target_blog = blogs[blog_handle] %}
{% assign max_posts   = section.settings.max_posts | default: 12 %}

<style>

.rtc-wrap {
  background: #FCEED9;
  padding: 60px 40px 80px;
}
.rtc-inner { max-width: 1200px; margin: 0 auto; }

.rtc-heading {
  text-align: center;
  font-size: 32px;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 36px;
  font-family: Georgia, serif;
}

/* ── TABS ── */
.rtc-tabs {
  display: flex;
  justify-content: center;
  margin-bottom: 40px;
  overflow-x: auto;
  scrollbar-width: none;
  gap: 40px;
  border-bottom: 1px solid #d4b896;
  padding-bottom: 0;
}
.rtc-tabs::-webkit-scrollbar { display: none; }
.rtc-tab {
  font-size: 14px;
  font-weight: 700;
  color: #888;
  cursor: pointer;
  padding: 0 4px 14px;
  border: none;
  background: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
  flex-shrink: 0;
  border-bottom: 3px solid transparent;
  margin-bottom: -1px;
  transition: color .2s;
}
.rtc-tab:hover  { color: #1b6b3a; }
.rtc-tab.active { color: #1b6b3a; border-bottom: 3px solid #1b6b3a; }

/* ── GRID ── */
.rtc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  min-height: 200px;
  transition: opacity 0.2s;
}

/* ── CARD ── */
.rtc-card {
  border-radius: 16px;
  overflow: hidden;
  background: #fff;
  cursor: pointer;
  transition: transform .25s ease, box-shadow .25s ease;
  text-decoration: none;
  display: flex;
  flex-direction: column;
}
.rtc-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.12); }
.rtc-card[hidden] { display: none; }

.rtc-card-img {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: #e8e0d5;
  flex-shrink: 0;
}
.rtc-card-img img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform .45s ease;
}
.rtc-card:hover .rtc-card-img img { transform: scale(1.06); }

/* Placeholder when no featured image */
.rtc-card-img-placeholder {
  width: 100%; height: 100%;
  background: #d4e8dc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rtc-card-body {
  background: #0e3a23;
  padding: 20px 20px 22px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.rtc-card-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #a8e0bc;
}
.rtc-card-title {
  font-size: 17px;
  font-weight: 700;
  line-height: 1.4;
  color: #fff;
  flex: 1;
}
.rtc-read-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #FCEED9;
  border: none;
  color: #1a1a1a;
  padding: 9px 18px;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 700;
  width: fit-content;
  text-decoration: none;
  transition: background .2s;
}
.rtc-read-btn:hover { background: #f5e0c0; }

.rtc-empty {
  grid-column: 1/-1;
  text-align: center;
  color: #888;
  padding: 60px 20px;
  font-size: 15px;
  line-height: 1.8;
}
.rtc-no-results {
  grid-column: 1/-1;
  text-align: center;
  color: #888;
  padding: 60px 20px;
  font-size: 15px;
  display: none;
}

@media (max-width: 768px) {
  .rtc-wrap { padding: 40px 16px 60px; }
  .rtc-heading { font-size: 24px; margin-bottom: 24px; }
  .rtc-tabs { gap: 20px; justify-content: flex-start; }
  .rtc-tab { font-size: 12px; padding: 0 2px 12px; }
  .rtc-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .rtc-card-title { font-size: 15px; }
}
@media (max-width: 480px) {
  .rtc-grid { grid-template-columns: 1fr; }
}
</style>

<div class="rtc-wrap">
  <div class="rtc-inner">

    {% if section.settings.heading != blank %}
      <h2 class="rtc-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <!-- Filter Tabs -->
    <div class="rtc-tabs" id="rtcTabs">
      <button class="rtc-tab active" data-tag="all">ALL</button>
      {% for block in section.blocks %}
        {% if block.type == 'filter_tab' %}
          <button
            class="rtc-tab"
            data-tag="{{ block.settings.tag_filter | downcase | strip }}"
          >{{ block.settings.tab_label }}</button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Blog Cards Grid — rendered server-side via Liquid -->
    <div class="rtc-grid" id="rtcGrid">

      {% if target_blog == blank %}

        <div class="rtc-empty">
          Blog not found.<br>
          <small>
            Please check the <strong>Blog Handle</strong> in section settings.<br>
            Current value: <strong>{{ blog_handle }}</strong><br>
            Go to <strong>Shopify Admin → Online Store → Blog posts → Manage blogs</strong>
            and copy the handle from the blog URL.
          </small>
        </div>

      {% else %}

        {% assign article_count = 0 %}

        {% for article in target_blog.articles limit: max_posts %}
          {% assign article_count = article_count | plus: 1 %}

          {% comment %} Build a comma-separated lowercase tag string for JS filtering {% endcomment %}
          {% assign tag_string = '' %}
          {% for tag in article.tags %}
            {% assign tag_lower = tag | downcase | strip %}
            {% if forloop.first %}
              {% assign tag_string = tag_lower %}
            {% else %}
              {% assign tag_string = tag_string | append: ',' | append: tag_lower %}
            {% endif %}
          {% endfor %}

          {% comment %} Pick first matching configured tab tag for the card label {% endcomment %}
          {% assign display_tag = '' %}
          {% for block in section.blocks %}
            {% if block.type == 'filter_tab' and display_tag == '' %}
              {% assign cfg_tag = block.settings.tag_filter | downcase | strip %}
              {% for art_tag in article.tags %}
                {% if art_tag == cfg_tag and display_tag == '' %}
                  {% assign display_tag = block.settings.tab_label %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endfor %}
          {% if display_tag == '' and article.tags.size > 0 %}
            {% assign display_tag = article.tags.first %}
          {% endif %}

          <a
            class="rtc-card"
            href="{{ article.url }}"
            data-tags="{{ tag_string }}"
          >
            <div class="rtc-card-img">
              {% if article.image %}
                <img
                  src="{{ article.image | img_url: '600x450', crop: 'center' }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {% else %}
                <div class="rtc-card-img-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1b6b3a" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <div class="rtc-card-body">
              {% if display_tag != '' %}
                <div class="rtc-card-tag">{{ display_tag }}</div>
              {% endif %}
              <div class="rtc-card-title">{{ article.title }}</div>
              <span class="rtc-read-btn">
                Read More
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </span>
            </div>
          </a>

        {% endfor %}

        {% if article_count == 0 %}
          <div class="rtc-empty">
            No blog posts found in <strong>{{ target_blog.title }}</strong>.<br>
            <small>Make sure posts are published and belong to this blog.</small>
          </div>
        {% endif %}

        <!-- Shown via JS when a filtered tab has zero results -->
        <div class="rtc-no-results" id="rtcNoResults">
          No blogs found in this category.<br>
          <small>Add the matching tag to your blog posts to show them here.</small>
        </div>

      {% endif %}

    </div><!-- /.rtc-grid -->

  </div>
</div>

<script>
(function () {

  var tabs    = document.querySelectorAll('#rtcTabs .rtc-tab');
  var cards   = document.querySelectorAll('#rtcGrid .rtc-card');
  var noRes   = document.getElementById('rtcNoResults');
  var grid    = document.getElementById('rtcGrid');

  function filterCards(tag) {
    var visible = 0;

    cards.forEach(function (card) {
      if (tag === 'all') {
        card.removeAttribute('hidden');
        visible++;
      } else {
        /* data-tags is a comma-separated lowercase string built by Liquid */
        var cardTags = (card.dataset.tags || '').split(',').map(function(t){ return t.trim(); });
        if (cardTags.indexOf(tag) !== -1) {
          card.removeAttribute('hidden');
          visible++;
        } else {
          card.setAttribute('hidden', '');
        }
      }
    });

    /* Show/hide the "no results" message */
    if (noRes) noRes.style.display = (visible === 0 ? 'block' : 'none');
  }

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      /* Update active tab */
      tabs.forEach(function (t) { t.classList.remove('active'); });
      tab.classList.add('active');

      var tag = tab.dataset.tag;

      /* Fade out → filter → fade in */
      grid.style.opacity = '0';
      setTimeout(function () {
        filterCards(tag);
        grid.style.opacity = '1';
      }, 180);
    });
  });

  /* Initial render — show all */
  filterCards('all');

}());
</script>

{% schema %}
{
  "name": "ankooram blogs grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Ankooram Blogs"
    },
    {
      "type": "text",
      "id": "blog_handle",
      "label": "Blog Handle",
      "info": "The URL handle of your blog. Go to Shopify Admin → Blog posts → Manage blogs. The handle is the last part of the blog URL. Example: /blogs/news → enter 'news'.",
      "default": "news"
    },
    {
      "type": "range",
      "id": "max_posts",
      "label": "Max Posts to Show",
      "min": 6,
      "max": 48,
      "step": 6,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "filter_tab",
      "name": "Filter Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab Label (displayed on screen)",
          "default": "RIGHT NUTRITION"
        },
        {
          "type": "text",
          "id": "tag_filter",
          "label": "Blog Tag",
          "info": "Enter the exact tag applied to your blog posts in Shopify. Tag matching is case-insensitive. Example: if the post has tag 'nutrition', enter 'nutrition'.",
          "default": "nutrition"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ankooram blogs grid",
      "blocks": [
        { "type": "filter_tab", "settings": { "tab_label": "RIGHT NUTRITION", "tag_filter": "nutrition" } },
        { "type": "filter_tab", "settings": { "tab_label": "RIGHT LIFESTYLE",  "tag_filter": "lifestyle"  } },
        { "type": "filter_tab", "settings": { "tab_label": "RIGHT MINDSET",    "tag_filter": "mindset"    } },
        { "type": "filter_tab", "settings": { "tab_label": "RIGHT HEALTH",     "tag_filter": "health"     } }
      ]
    }
  ]
}
{% endschema %}
