    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    opacity: 0.4;
  }
  .pfq__card-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pfq__card-title {
    font-family: var(--pfq-font-display);
    font-size: 18px;
    font-weight: 500;
    margin: 0 0 6px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .pfq__card-desc {
    font-size: 13px;
    color: var(--pfq-text-muted);
    line-height: 1.5;
    margin: 0 0 14px;
    flex: 1;
  }
  .pfq__card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid var(--pfq-border);
  }
  .pfq__card-price {
    font-family: var(--pfq-font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--pfq-text);
  }
  .pfq__card-cta {
    font-size: 13px;
    font-weight: 600;
