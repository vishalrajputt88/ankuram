  }

  .pfq__results-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 640px) {
    #pfq-{{ section.id }} {
      padding: 50px 16px;
    }
    .pfq__options--grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .pfq__options--two {
      grid-template-columns: 1fr;
    }
    .pfq__option {
      padding: 16px 18px;
    }
    .pfq__results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .pfq__card-body {
      padding: 14px 14px 16px;
    }
    .pfq__card-title {
      font-size: 15px;
    }
    .pfq__btn {
      padding: 14px 24px;
      font-size: 14px;
    }
    .pfq__results-actions {
      flex-direction: column;
    }
    .pfq__results-actions .pfq__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

