{% assign ankooram_slider = section.id | replace: '_', '' | downcase %}

{% style %}
.ankooram-slider-nav-{{ ankooram_slider }} svg { width: 34px; height: 34px; }
  .ankooram-slider-{{ ankooram_slider }} {
    position: relative;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
    overflow: hidden;
    /* border-radius: {{ section.settings.border_radius }}px; */
  }

  /* ===== DESKTOP WRAPPER ===== */
  .ankooram-slider-wrapper-{{ ankooram_slider }} {
    position: relative;
    width: 100%;
    /* max-height: 500px; */
    /* aspect-ratio: 20 / 7; */
  }

  .ankooram-slider-track-{{ ankooram_slider }} {
    display: flex;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ankooram-slider-slide-{{ ankooram_slider }} {
    /* position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%; */
    opacity: 0;
    display: none;
    transition: opacity {{ section.settings.transition_speed }}s ease-in-out;
  }

  .ankooram-slider-slide-{{ ankooram_slider }}.active {
    opacity: 1;
    z-index: 1;
    width: 100%;
    display: block;
  }

  .ankooram-slider-image-{{ ankooram_slider }} {
    /* position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }}; */
  }

  /* Mobile image - hidden on desktop */
  .ankooram-slider-mobile-image-{{ ankooram_slider }} {
    display: none;
  
  }

  .ankooram-slider-placeholder-{{ ankooram_slider }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #7cb342 0%, #558b2f 50%, #33691e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ankooram-slider-placeholder-{{ ankooram_slider }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.15;
  }

  /* {% if section.settings.overlay_style == 'left_fade' %}
