{% comment %}
  Section: Custom Collection Banner
{% endcomment %}

<section class="custom-partition-hero">
  <div class="hero-bg" style="background-image: url({{ section.settings.bg_image | image_url: width: 2000 }});">
    
    <div class="overlay" style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity }};"></div>

    <div class="hero-content {{ section.settings.text_align }}">
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="subheading">{{ section.settings.subheading }}</p>
      {% endif %}

     {% if section.settings.description != blank %}
  <div class="description">
    {{ section.settings.description }}
  </div>
{% endif %}
    </div>

  </div>
</section>

<style>
.custom-partition-hero {
  position: relative;
  width: 100%;
}

.custom-partition-hero .hero-bg {
  position: relative;
  height: 500px;
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-partition-hero .overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.custom-partition-hero .hero-content {
  position: relative;
  z-index: 2;
  max-width: 700px;
  padding: 20px;
  color: #fff;
}

.custom-partition-hero .hero-content.center {
  text-align: center;
}

.custom-partition-hero .hero-content.left {
  text-align: left;
}

.custom-partition-hero .hero-content.right {
  text-align: right;
}

.custom-partition-hero h1 {
  font-size: 48px;
  font-weight: 800;
  letter-spacing: 2px;
  margin-bottom: 10px;
}

.custom-partition-hero .subheading {
  font-size: 18px;
  margin-bottom: 10px;
  opacity: 0.9;
}

.custom-partition-hero .description {
  font-size: 14px;
  line-height: 1.6;
  opacity: 0.8;
}

@media (max-width: 768px) {
  .custom-partition-hero .hero-bg {
    height: 400px;
  }

  .custom-partition-hero h1 {
    font-size: 30px;
  }
}
</style>

{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Indoor Plant"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Green Living"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}